# ============================================
# Unity 프로젝트 .gitignore
# (Unity 프로젝트는 UnityLab/ 하위에 위치하므로
#  디렉터리 패턴은 루트에 고정하지 않아 어느 깊이에서나 매칭됨)
# ============================================

# Unity가 자동 생성하는 폴더 (커밋 불필요)
[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
[Ll]ogs/
[Uu]ser[Ss]ettings/
[Mm]emoryCaptures/

# Asset Store 도구가 생성하는 폴더
[Aa]ssets/AssetStoreTools*

# Unity가 자동 생성하는 데모 폴더
[Aa]ssets/[Ss]treamingAssets/aassetbundles*

# Autogenerated VS / Rider / VSCode 프로젝트 파일
.vs/
.idea/
ExportedObj/
.consulo/
*.csproj
*.unityproj
*.sln
*.slnx
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# Unity3D 가 생성하는 메타 파일은 빈 폴더 전용으로 무시
# (폴더 안에 다른 파일이 있으면 .meta 는 함께 커밋해야 함)
sysinfo.txt

# 빌드 결과물
*.apk
*.aab
*.unitypackage
*.app

# 크래시 리포트
crashlytics-build.properties

# 참고: Packages/ 폴더의 manifest.json, packages-lock.json 은
#       커밋해야 하므로 무시하지 않음

# OS 생성 파일
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
[Tt]humbs.db
[Dd]esktop.ini

# Rider
*.sln.iml
